# === CDNetworks Platform — secrets template ===
# Copy file này thành .env và thay giá trị thật.
JWT_SECRET=replace-with-openssl-rand-hex-32

# Bootstrap admin user (dev only, production hãy dùng Postgres)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe!Strong#Password

# Public URLs
NEXT_PUBLIC_API_BASE=https://console-cdnetworks.vnso.vn
NEXT_PUBLIC_CONSOLE_URL=https://console-cdnetworks.vnso.vn
NEXT_PUBLIC_DOCS_URL=https://cdnetworks.vnso.vn/document

# CORS cho API
CORS_ORIGINS=https://console-cdnetworks.vnso.vn,https://cdnetworks.vnso.vn

# === Full-stack (kích hoạt khi deploy docker-compose.full.yml) ===
# POSTGRES_USER=cdn
# POSTGRES_PASSWORD=cdn-strong-pass
# POSTGRES_DB=cdn
# REDIS_PASSWORD=redis-strong-pass
# CLICKHOUSE_USER=cdn
# CLICKHOUSE_PASSWORD=ch-strong-pass
# KAFKA_BOOTSTRAP=kafka:9092
