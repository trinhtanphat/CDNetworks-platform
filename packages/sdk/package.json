{
  "name": "@cdn/sdk",
  "version": "0.1.0",
  "description": "Official typed TypeScript/JavaScript SDK for CDNetworks Platform API.",
  "license": "MIT",
  "type": "module",
  "main":    "./dist/index.cjs",
  "module":  "./dist/index.js",
  "types":   "./dist/index.d.ts",
  "exports": {
    ".": {
      "types":   "./dist/index.d.ts",
      "import":  "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./errors": {
      "types":   "./dist/errors.d.ts",
      "import":  "./dist/errors.js",
      "require": "./dist/errors.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build":   "tsup src/index.ts src/errors.ts --format esm,cjs --dts --clean --sourcemap",
    "dev":     "tsup src/index.ts src/errors.ts --format esm,cjs --dts --watch",
    "test":    "vitest run",
    "lint":    "eslint src --ext .ts"
  },
  "dependencies": {
    "undici": "^6.19.2"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsup":        "^8.1.0",
    "typescript":  "^5.5.3",
    "vitest":      "^1.6.0"
  },
  "engines": { "node": ">=18.17.0" }
}
